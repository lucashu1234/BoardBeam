<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <!-- 注册 section handler：否则 System.Windows.Forms.ApplicationConfigurationSection 会被 .NET 静默忽略 -->
  <configSections>
    <section name="System.Windows.Forms.ApplicationConfigurationSection"
             type="System.Windows.Forms.ApplicationConfigurationSection, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" />
  </configSections>
  <!-- 启用 .NET Framework WinForms 的 PerMonitorV2 高 DPI 支持（与 app.manifest 配合）。
       manifest 负责进程级 DPI 感知（截图清晰），此处开关负责 WinForms 控件的高 DPI 特性
       （位图重采样、ToolStrip/CheckedListBox/DataGridView 高 DPI 改进、自动重布局）。 -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2"/>
    <add key="CheckedListBox.SupportHighDpiImprovements" value="true"/>
    <add key="DataGridView.SupportHighDpiImprovements" value="true"/>
  </System.Windows.Forms.ApplicationConfigurationSection>
</configuration>
