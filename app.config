<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
  </startup>
  <!-- 启用 .NET Framework WinForms 的 PerMonitorV2 自动缩放。
       与 app.manifest 的 dpiAwareness 声明配合，实现：
       - 跨不同 DPI 显示器时控件/字体自动重布局
       - CopyFromScreen 在物理像素坐标工作（截图清晰）
       - WM_DPICHANGED 时窗体位置/尺寸自动调整 -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2"/>
    <!-- 启用高 DPI 改进（.NET Framework 4.8）：控件布局与位图缩放 -->
    <add key="CheckedListBox.SupportHighDpiImprovements" value="true"/>
  </System.Windows.Forms.ApplicationConfigurationSection>
</configuration>
